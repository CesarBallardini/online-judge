# DMOJ Docker Environment Configuration
# Copy to .env and update values before first run
# Or run: ./manage.sh init

# --- Network ---
# Your server's LAN IP -- the single place to change when your IP changes
HOST_IP=192.168.0.3

# --- Debug ---
DEBUG=False

# --- Database ---
# Generate passwords: openssl rand -hex 16
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_DATABASE=dmoj
MYSQL_USER=dmoj
MYSQL_PASSWORD=change_this_mysql_password

# --- Django ---
# Generate: openssl rand -hex 32
SECRET_KEY=change_this_secret_key_in_production
TIME_ZONE=America/Argentina/Buenos_Aires

# --- Judge ---
# Must match the judge key configured in the admin panel (Admin > Judges)
JUDGE_NAME=paradigmas
JUDGE_KEY=change_this_judge_key

# --- Bridge ---
# Generate: openssl rand -hex 32
BRIDGE_API_KEY=change_this_bridge_api_key

# --- Admin API ---
# Used by ./manage.sh load-students, load-teachers, load-problems
# Generate: openssl rand -hex 32
ADMIN_API_KEY=change_this_admin_api_key
