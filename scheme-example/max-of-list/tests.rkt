(test "empty list" (max-of-list '()) error)
(test "single element" (max-of-list '(42)) 42)
(test "two elements" (max-of-list '(3 7)) 7)
(test "negative numbers" (max-of-list '(-5 -1 -10)) -1)
(test "mixed signs" (max-of-list '(-3 0 5 -1 2)) 5)
(test "large list" (max-of-list '(15 -3 42 8 -17 99 0 -5 23 67)) 99)
(test "all same" (max-of-list '(7 7 7 7)) 7)
(test "all zeros" (max-of-list '(0 0 0 0 0)) 0)
(test "reverse order" (max-of-list '(10 3)) 10)
(test "boundary values" (max-of-list '(999999 -999999)) 999999)
